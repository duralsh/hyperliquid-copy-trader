{
  "name": "arena-perps-trading-agent",
  "version": "1.0.0",
  "description": "Perpetuals trading agent for The Arena / Hyperliquid",
  "main": "dist/arena-perps-agent.js",
  "scripts": {
    "build": "tsc --noEmitOnError false",
    "start": "tsx src/arena-perps-agent.ts",
    "dev": "tsx watch src/arena-perps-agent.ts",
    "copy-trade": "tsx src/copytrading/index.ts",
    "dashboard:server": "cd dashboard/server && npm run dev",
    "dashboard:client": "cd dashboard/client && npx vite --port 5173",
    "dashboard:dev": "cd dashboard/server && npm run dev",
    "dashboard:build": "cd dashboard/client && npx vite build && cd ../server && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "dotenv": "^16.4.5",
    "viem": "^2.21.54",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
